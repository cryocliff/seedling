__pycache__/
*.pyc
*.egg-info/
.venv/
build/
dist/

# Sphinx docs build output (docs/conf.py); published by the Docs workflow.
docs/_build/
# docs/index.md is generated from README.md at build time (see docs/conf.py).
docs/index.md

# Distribution-only offline payloads (see docs/OFFLINE.md): uv binary,
# portable git, pre-seeded VS Code. Never committed; placed by whoever
# prepares an offline share.
vendor/

# Output of build-offline.cmd (the assembled offline bundle). A distribution
# artifact, not source -- carried to the air-gapped share, never committed.
offline-bundle/
